def cell4_avatar_processor(config):
    """Advanced face detection, enhancement, and silver chain realism"""
    import cv2
    import numpy as np
    import mediapipe as mp
    from PIL import Image, ImageEnhance
    from tqdm import tqdm
    
    class AvatarProcessor:
        def __init__(self, config):
            self.config = config
            self.mp_face_mesh = mp.solutions.face_mesh
            self.face_mesh = self.mp_face_mesh.FaceMesh(
                static_image_mode=False, max_num_faces=1,
                refine_landmarks=True, min_detection_confidence=0.5,
                min_tracking_confidence=0.5
            )
        
        def detect_face_region(self, frame):
            rgb = cv2.cvtColor(frame, cv2.COLOR_BGR2RGB)
            results = self.face_mesh.process(rgb)
            if results.multi_face_landmarks:
                landmarks = results.multi_face_landmarks[0].landmark
                h, w = frame.shape[:2]
                x_coords = [int(lm.x * w) for lm in landmarks]
                y_coords = [int(lm.y * h) for lm in landmarks]
                x_min, x_max = min(x_coords), max(x_coords)
                y_min, y_max = min(y_coords), max(y_coords)
                pad_x = int((x_max - x_min) * 0.2)
                pad_y = int((y_max - y_min) * 0.3)
                x_min = max(0, x_min - pad_x)
                x_max = min(w, x_max + pad_x)
                y_min = max(0, y_min - pad_y)
                y_max = min(h, y_max + pad_y)
                return (x_min, y_min, x_max, y_max), landmarks
            return None, None
        
        def enhance_silver_chain(self, frame, landmarks):
            """Make silver chain more realistic and prominent as brand logo"""
            if landmarks is None:
                return frame
            h, w = frame.shape[:2]
            output = frame.copy()
            
            # Neck landmarks for chain region
            neck_indices = [152, 148, 176, 149, 150, 136, 172, 58, 132, 93]
            neck_points = []
            for idx in neck_indices:
                if idx < len(landmarks):
                    x = int(landmarks[idx].x * w)
                    y = int(landmarks[idx].y * h)
                    neck_points.append((x, y))
            
            if len(neck_points) < 3:
                return frame
            
            mask = np.zeros((h, w), dtype=np.uint8)
            pts = np.array(neck_points, np.int32)
            cv2.fillPoly(mask, [pts], 255)
            kernel = cv2.getStructuringElement(cv2.MORPH_ELLIPSE, (15, 15))
            mask = cv2.dilate(mask, kernel, iterations=2)
            
            # Enhance metallic appearance
            lab = cv2.cvtColor(output, cv2.COLOR_BGR2LAB)
            l, a, b = cv2.split(lab)
            clahe = cv2.createCLAHE(clipLimit=3.0, tileGridSize=(8, 8))
            l_enhanced = clahe.apply(l)
            l_masked = l.copy()
            l_masked[mask > 0] = l_enhanced[mask > 0]
            
            sharpen_kernel = np.array([[-1,-1,-1],[-1,9,-1],[-1,-1,-1]])
            sharpened = cv2.filter2D(output, -1, sharpen_kernel)
            alpha = 0.3
            output[mask > 0] = cv2.addWeighted(output, 1-alpha, sharpened, alpha, 0)[mask > 0]
            
            # Add metallic shine
            shine = np.zeros_like(output)
            shine[mask > 0] = [220, 220, 230]
            output = cv2.addWeighted(output, 1.0, shine, 0.08, 0)
            
            return output
        
        def remove_original_lip_movement(self, frame, landmarks):
            """Neutralize original lip movements for clean lip-sync overlay"""
            if landmarks is None:
                return frame
            h, w = frame.shape[:2]
            output = frame.copy()
            
            lip_indices = [61, 146, 91, 181, 84, 17, 314, 405, 321, 375, 291, 409, 270, 269, 267, 0, 37, 39, 40, 185]
            lip_points = []
            for idx in lip_indices:
                if idx < len(landmarks):
                    x = int(landmarks[idx].x * w)
                    y = int(landmarks[idx].y * h)
                    lip_points.append((x, y))
            
            if len(lip_points) < 4:
                return frame
            
            mask = np.zeros((h, w), dtype=np.uint8)
            pts = np.array(lip_points, np.int32)
            cv2.fillPoly(mask, [pts], 255)
            kernel = cv2.getStructuringElement(cv2.MORPH_ELLIPSE, (8, 8))
            mask = cv2.dilate(mask, kernel, iterations=1)
            
            dilated_mask = cv2.dilate(mask, np.ones((20, 20), np.uint8), iterations=2)
            surrounding = dilated_mask - mask
            skin_color = cv2.mean(frame, mask=surrounding)[:3]
            neutral_color = tuple(int(c * 0.85) for c in skin_color)
            colored_lip = np.full_like(frame, neutral_color)
            
            mask_float = mask.astype(float) / 255.0
            mask_3ch = np.stack([mask_float] * 3, axis=-1)
            output = (output * (1 - mask_3ch) + colored_lip * mask_3ch).astype(np.uint8)
            
            blurred = cv2.GaussianBlur(output, (5, 5), 0)
            edge_mask = cv2.dilate(mask, np.ones((3,3), np.uint8), iterations=1) - cv2.erode(mask, np.ones((3,3), np.uint8), iterations=1)
            edge_mask_3ch = np.stack([edge_mask.astype(float)/255.0] * 3, axis=-1)
            output = (output * (1 - edge_mask_3ch) + blurred * edge_mask_3ch).astype(np.uint8)
            
            return output
        
        def enhance_face_realism(self, frame):
            pil_img = Image.fromarray(cv2.cvtColor(frame, cv2.COLOR_BGR2RGB))
            enhancer = ImageEnhance.Sharpness(pil_img)
            pil_img = enhancer.enhance(1.2)
            enhancer = ImageEnhance.Color(pil_img)
            pil_img = enhancer.enhance(1.05)
            enhancer = ImageEnhance.Contrast(pil_img)
            pil_img = enhancer.enhance(1.05)
            return cv2.cvtColor(np.array(pil_img), cv2.COLOR_RGB2BGR)
        
        def process_avatar_frame(self, frame, neutralize_lips=True, enhance_chain=True):
            bbox, landmarks = self.detect_face_region(frame)
            if neutralize_lips and landmarks is not None:
                frame = self.remove_original_lip_movement(frame, landmarks)
            if enhance_chain and landmarks is not None:
                frame = self.enhance_silver_chain(frame, landmarks)
            frame = self.enhance_face_realism(frame)
            return frame, bbox, landmarks
        
        def process_avatar_video(self, input_path, output_path, neutralize_lips=True, enhance_chain=True):
            cap = cv2.VideoCapture(input_path)
            fps = cap.get(cv2.CAP_PROP_FPS)
            width = int(cap.get(cv2.CAP_PROP_FRAME_WIDTH))
            height = int(cap.get(cv2.CAP_PROP_FRAME_HEIGHT))
            total_frames = int(cap.get(cv2.CAP_PROP_FRAME_COUNT))
            
            fourcc = cv2.VideoWriter_fourcc(*'mp4v')
            out = cv2.VideoWriter(output_path, fourcc, fps, (width, height))
            
            print(f"🎬 Processing {total_frames} frames...")
            for i in tqdm(range(total_frames), desc="Processing avatar"):
                ret, frame = cap.read()
                if not ret:
                    break
                processed, _, _ = self.process_avatar_frame(frame, neutralize_lips, enhance_chain)
                out.write(processed)
            
            cap.release()
            out.release()
            print(f"✅ Avatar processed: {output_path}")
            return output_path
    
    return AvatarProcessor(config)


