def cell8_video_engine(config):
    """Compose final videos with scenes, overlays, and effects"""
    from moviepy.editor import *
    from moviepy.video.fx.all import *
    import numpy as np
    import cv2
    import random
    
    class VideoEngine:
        def __init__(self, config):
            self.config = config
        
        def create_text_overlay(self, text, size=(1080, 200), font_size=60, 
                                 color='white', stroke_color='black', stroke_width=2):
            """Create styled text clip"""
            txt_clip = TextClip(
                text, fontsize=font_size, color=color,
                stroke_color=stroke_color, stroke_width=stroke_width,
                font='Arial-Bold', method='caption', size=(size[0]-100, None),
                align='center'
            )
            txt_clip = txt_clip.set_position('center')
            
            # Add background
            bg = ColorClip(size=(size[0], txt_clip.h + 40), color=(0, 0, 0, 180))
            bg = bg.set_opacity(0.7)
            
            composite = CompositeVideoClip([bg, txt_clip.set_position('center')])
            return composite
        
        def create_hook_overlay(self, hook_text, duration=3):
            """Create attention-grabbing hook overlay"""
            txt = TextClip(
                hook_text, fontsize=80, color='yellow',
                stroke_color='red', stroke_width=3,
                font='Arial-Bold', method='caption', size=(980, None),
                align='center'
            )
            txt = txt.set_duration(duration).set_position('center')
            
            # Pulsing effect
            txt = txt.fx(vfx.resize, lambda t: 1 + 0.05 * np.sin(t * 8))
            
            # Background flash
            flash = ColorClip(size=(1080, 1920), color=(255, 255, 255))
            flash = flash.set_duration(0.3).set_opacity(0.3)
            
            return txt, flash
        
        def create_subtitle_clip(self, text, duration, position=('center', 1600)):
            """Create subtitle text with styling"""
            words = text.split()
            clips = []
            word_duration = duration / max(len(words), 1)
            
            for i, word in enumerate(words):
                # Highlight current word
                highlighted = ' '.join([
                    f"\\textcolor{{yellow}}{{{w}}}" if j == i else w 
                    for j, w in enumerate(words)
                ])
                
                txt = TextClip(
                    text, fontsize=50, color='white',
                    stroke_color='black', stroke_width=2,
                    font='Arial-Bold', method='caption', size=(980, None),
                    align='center'
                )
                txt = txt.set_duration(word_duration).set_position(position)
                clips.append(txt)
            
            return concatenate_videoclips(clips) if clips else None
        
        def create_background_scene(self, scene_type, duration=4):
            """Generate or load background scene"""
            # Create colored gradient background as placeholder
            # In production, this would load actual car footage
            
            colors = {
                'luxury_car_interior': (20, 20, 30),
                'car_engine_closeup': (40, 40, 40),
                'highway_driving': (60, 80, 120),
                'car_wash_detail': (100, 150, 200),
                'garage_workspace': (50, 50, 50),
                'sunset_drive': (200, 100, 50),
                'city_traffic': (80, 80, 100),
                'mechanic_tools': (60, 60, 70),
            }
            
            color = colors.get(scene_type, (30, 30, 40))
            
            # Create gradient
            def make_gradient(t):
                frame = np.zeros((1920, 1080, 3), dtype=np.uint8)
                for y in range(1920):
                    ratio = y / 1920
                    r = int(color[0] * (1 - ratio * 0.5))
                    g = int(color[1] * (1 - ratio * 0.3))
                    b = int(color[2] * (1 - ratio * 0.2))
                    frame[y, :] = [r, g, b]
                return frame
            
            clip = VideoClip(make_gradient, duration=duration)
            
            # Add subtle movement
            clip = clip.fx(vfx.scroll, 20, 20)
            
            return clip
        
        def compose_video(self, avatar_clip, audio_clip, script_data, output_path,
                          platform='youtube_shorts', num_scenes=5):
            """Compose final video with all elements"""
            print(f"\\n🎬 Composing {platform} video...")
            
            # Get platform settings
            platform_config = self.config.PLATFORMS[platform]
            target_duration = min(script_data['duration'], platform_config['duration'])
            
            # Resize avatar to fit
            avatar_w, avatar_h = self.config.AVATAR_SIZE
            avatar_clip = avatar_clip.resize(width=avatar_w)
            
            # Position avatar
            if self.config.AVATAR_POSITION == ('right', 'bottom'):
                avatar_pos = (1080 - avatar_w - self.config.AVATAR_PADDING, 
                             1920 - avatar_clip.h - self.config.AVATAR_PADDING)
            else:
                avatar_pos = ('center', 'bottom')
            
            avatar_clip = avatar_clip.set_position(avatar_pos)
            
            # Create background scenes
            scene_duration = target_duration / num_scenes
            scenes = []
            for i in range(num_scenes):
                scene_type = random.choice(self.config.BG_SCENES)
                scene = self.create_background_scene(scene_type, scene_duration)
                scenes.append(scene)
            
            background = concatenate_videoclips(scenes)
            background = background.loop(duration=target_duration)
            
            # Add hook at beginning
            hook_clip, flash = self.create_hook_overlay(script_data['hook'], 3)
            hook_clip = hook_clip.set_start(0)
            
            # Add title overlay
            title = self.create_text_overlay(
                script_data['title'], size=(1080, 150), font_size=70, color='yellow'
            )
            title = title.set_duration(4).set_start(3).set_position(('center', 200))
            
            # Add tips as overlays
            tip_clips = []
            tip_start = 7
            for i, tip in enumerate(script_data['tips']):
                tip_text = f"💡 {tip}"
                tip_clip = self.create_text_overlay(tip_text, size=(1000, 200), font_size=45)
                tip_clip = tip_clip.set_duration(8).set_start(tip_start + i * 9)
                tip_clip = tip_clip.set_position(('center', 1400))
                tip_clips.append(tip_clip)
            
            # Add CTA at end
            cta = self.create_text_overlay(
                "Follow for more tips! 🔧\\nDrop a comment below! 👇",
                size=(1080, 200), font_size=55, color='cyan'
            )
            cta = cta.set_duration(5).set_start(target_duration - 5)
            cta = cta.set_position(('center', 1500))
            
            # Compose all layers
            layers = [background, avatar_clip, hook_clip, title] + tip_clips + [cta]
            
            final = CompositeVideoClip(layers, size=(1080, 1920))
            final = final.set_duration(target_duration)
            final = final.set_audio(audio_clip)
            
            # Add subtle zoom effect
            final = final.fx(vfx.resize, lambda t: 1 + 0.02 * np.sin(t * 0.5))
            
            # Render
            final.write_videofile(
                output_path,
                fps=self.config.FPS,
                codec='libx264',
                audio_codec='aac',
                temp_audiofile=f"{self.config.TEMP_DIR}/temp_audio.m4a",
                remove_temp=True,
                threads=4,
                preset='medium',
                bitrate='8000k'
            )
            
            print(f"✅ Video saved: {output_path}")
            return output_path
    
    return VideoEngine(config)


