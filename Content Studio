            results = {}
            
            for platform, (w, h) in sizes.items():
                resized = video.resize(newsize=(w, h))
                output = f"{output_dir}/{platform}_{os.path.basename(video_path)}"
                resized.write_videofile(output, fps=30, codec='libx264')
                results[platform] = output
                resized.close()
            
            video.close()
            return results
    
    return AdvancedFeatures()


