def cell5_lipsync_engine(config):
    """Wav2Lip-based lip synchronization"""
    import sys
    sys.path.insert(0, '/content/car_ai_studio/wav2lip')
    
    import torch
    import cv2
    import numpy as np
    from tqdm import tqdm
    
    try:
        import face_detection
        import audio
        from models import Wav2Lip
    except ImportError as e:
        print(f"⚠️  Wav2Lip import issue: {e}")
        print("Using fallback lip-sync method...")
        return None
    
    class LipSyncEngine:
        def __init__(self, config):
            self.config = config
            self.device = torch.device('cuda' if torch.cuda.is_available() else 'cpu')
            self.model = self._load_model()
            self.detector = face_detection.FaceAlignment(
                face_detection.LandmarksType._2D,
                flip_input=False, device=str(self.device)
            )
        
        def _load_model(self):
            model_path = f"{self.config.MODELS_DIR}/wav2lip_gan.pth"
            if not os.path.exists(model_path):
                model_path = f"{self.config.MODELS_DIR}/wav2lip.pth"
            
            model = Wav2Lip()
            checkpoint = torch.load(model_path, map_location=self.device)
            s = checkpoint["state_dict"] if "state_dict" in checkpoint else checkpoint
            new_s = {}
            for k, v in s.items():
                new_s[k.replace('module.', '')] = v
            model.load_state_dict(new_s)
            model = model.to(self.device)
            model.eval()
            print(f"🎭 Wav2Lip loaded on {self.device}")
            return model
        
        def _load_audio(self, audio_path):
            wav = audio.load_wav(audio_path, 16000)
            mel = audio.melspectrogram(wav)
            mel = (mel - mel.mean()) / mel.std()
            return mel, wav
        
        def _detect_faces(self, frames):
            faces = []
            for frame in frames:
                preds = self.detector.get_detections_for_image(np.array(frame))
                if len(preds) > 0:
                    face = max(preds, key=lambda x: (x[2]-x[0])*(x[3]-x[1]))
                    faces.append(face)
                else:
                    faces.append(None)
            return faces
        
        def _crop_face(self, frame, face, pad=0.2):
            if face is None:
                return None, None
            x1, y1, x2, y2 = face
            h, w = frame.shape[:2]
            pad_h = int((y2 - y1) * pad)
            pad_w = int((x2 - x1) * pad)
            x1 = max(0, x1 - pad_w)
            y1 = max(0, y1 - pad_h)
            x2 = min(w, x2 + pad_w)
            y2 = min(h, y2 + pad_h)
            face_img = frame[y1:y2, x1:x2]
            return face_img, (x1, y1, x2, y2)
        
        def _preprocess_face(self, face_img, size=96):
            if face_img is None:
                return None
            face_img = cv2.resize(face_img, (size, size))
            face_img = cv2.cvtColor(face_img, cv2.COLOR_BGR2RGB)
            face_img = (face_img / 255.0).astype(np.float32)
            face_tensor = torch.from_numpy(face_img).permute(2, 0, 1).unsqueeze(0)
            return face_tensor.to(self.device)
        
        def generate_lip_sync(self, face_video_path, audio_path, output_path, batch_size=16):
            print("\n🎬 Starting lip-sync generation...")
            mel, wav = self._load_audio(audio_path)
            
            reader = cv2.VideoCapture(face_video_path)
            fps = reader.get(cv2.CAP_PROP_FPS)
            total_frames = int(reader.get(cv2.CAP_PROP_FRAME_COUNT))
            
            frames = []
            for _ in range(total_frames):
                ret, frame = reader.read()
                if not ret:
                    break
                frames.append(frame)
            reader.release()
            
            print(f"   Video: {len(frames)} frames @ {fps}fps")
            print(f"   Audio: {mel.shape[1]} mel frames")
            
            faces = self._detect_faces(frames)
            
            h, w = frames[0].shape[:2]
            fourcc = cv2.VideoWriter_fourcc(*'mp4v')
            out = cv2.VideoWriter(output_path, fourcc, fps, (w, h))
            
            print("\n🎭 Generating lip movements...")
            mel_idx_multiplier = 80.0 / fps
            
            for i in tqdm(range(0, len(frames), batch_size), desc="Lip-sync batches"):
                batch_frames = frames[i:i+batch_size]
                batch_faces = faces[i:i+batch_size]
                
                face_tensors = []
                mel_chunks = []
                coords = []
                valid_indices = []
                
                for j, (frame, face) in enumerate(zip(batch_frames, batch_faces)):
                    if face is None:
                        continue
                    face_img, coord = self._crop_face(frame, face)
                    face_tensor = self._preprocess_face(face_img)
                    if face_tensor is None:
                        continue
                    
                    mel_idx = int((i + j) * mel_idx_multiplier)
                    mel_chunk = mel[:, mel_idx:mel_idx+16]
                    if mel_chunk.shape[1] < 16:
                        pad_width = 16 - mel_chunk.shape[1]
                        mel_chunk = np.pad(mel_chunk, ((0,0), (0, pad_width)), mode='edge')
                    
                    mel_tensor = torch.from_numpy(mel_chunk).unsqueeze(0).to(self.device)
                    
                    face_tensors.append(face_tensor)
                    mel_chunks.append(mel_tensor)
                    coords.append(coord)
                    valid_indices.append(j)
                
                if not face_tensors:
                    for frame in batch_frames:
                        out.write(frame)
                    continue
                
                face_batch = torch.cat(face_tensors, dim=0)
                mel_batch = torch.cat(mel_chunks, dim=0)
                
                with torch.no_grad():
                    pred = self.model(mel_batch, face_batch)
                
                for j, (frame, coord, idx) in enumerate(zip(
                    [batch_frames[v] for v in valid_indices], coords, valid_indices)):
                    
                    pred_face = pred[j].cpu().numpy().transpose(1, 2, 0)
                    pred_face = (pred_face * 255).astype(np.uint8)
                    pred_face = cv2.cvtColor(pred_face, cv2.COLOR_RGB2BGR)
                    
                    x1, y1, x2, y2 = coord
                    pred_face = cv2.resize(pred_face, (x2-x1, y2-y1))
                    
                    mask = np.ones((y2-y1, x2-x1), dtype=np.float32)
                    feather = 5
                    mask[:feather, :] *= np.linspace(0, 1, feather)[:, None]
                    mask[-feather:, :] *= np.linspace(1, 0, feather)[:, None]
                    mask[:, :feather] *= np.linspace(0, 1, feather)[None, :]
                    mask[:, -feather:] *= np.linspace(1, 0, feather)[None, :]
                    
                    mask_3ch = np.stack([mask] * 3, axis=-1)
                    roi = frame[y1:y2, x1:x2]
                    blended = (roi * (1 - mask_3ch) + pred_face * mask_3ch).astype(np.uint8)
                    frame[y1:y2, x1:x2] = blended
                    batch_frames[idx] = frame
                
                for frame in batch_frames:
                    out.write(frame)
            
            out.release()
            torch.cuda.empty_cache()
            print(f"\n✅ Lip-sync complete: {output_path}")
            return output_path
    
    return LipSyncEngine(config)


