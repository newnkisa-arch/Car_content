def cell7_audio_engine(config):
    """Generate voiceovers and process background music"""
    import edge_tts
    import asyncio
    from pydub import AudioSegment
    import os
    
    class AudioEngine:
        def __init__(self, config):
            self.config = config
            self.voice = config.VOICE
            self.music_dir = config.MUSIC_DIR
        
        async def _generate_voice(self, text, output_path, voice=None, rate="+0%", pitch="+0Hz"):
            if voice is None:
                voice = self.voice
            communicate = edge_tts.Communicate(text, voice, rate=rate, pitch=pitch)
            await communicate.save(output_path)
        
        def generate_voiceover(self, text, output_path, voice=None):
            """Generate voiceover using Edge TTS"""
            loop = asyncio.new_event_loop()
            asyncio.set_event_loop(loop)
            loop.run_until_complete(self._generate_voice(text, output_path, voice))
            loop.close()
            return output_path
        
        def add_background_music(self, voice_path, output_path, music_path=None, 
                                  voice_vol=0, music_vol=-20, fade_in=2000, fade_out=3000):
            """Mix voiceover with background music"""
            voice = AudioSegment.from_file(voice_path)
            
            if music_path and os.path.exists(music_path):
                music = AudioSegment.from_file(music_path)
            else:
                # Use fallback music
                fallback = f"{self.music_dir}/fallback.mp3"
                if os.path.exists(fallback):
                    music = AudioSegment.from_file(fallback)
                else:
                    # Create silent track
                    music = AudioSegment.silent(duration=len(voice))
            
            # Adjust music length to match voice
            if len(music) < len(voice):
                # Loop music
                loops_needed = (len(voice) // len(music)) + 1
                music = music * loops_needed
            
            music = music[:len(voice)]
            
            # Apply volume adjustments
            voice = voice + voice_vol
            music = music + music_vol
            
            # Fade in/out
            music = music.fade_in(fade_in).fade_out(fade_out)
            
            # Mix
            mixed = voice.overlay(music)
            mixed.export(output_path, format="mp3", bitrate="192k")
            
            return output_path
        
        def normalize_audio(self, input_path, output_path, target_dBFS=-14):
            """Normalize audio to target level"""
            audio = AudioSegment.from_file(input_path)
            change_in_dBFS = target_dBFS - audio.dBFS
            normalized = audio.apply_gain(change_in_dBFS)
            normalized.export(output_path, format="mp3")
            return output_path
    
    return AudioEngine(config)


