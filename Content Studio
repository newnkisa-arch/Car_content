def cell6_content_engine(config):
    """Generate viral car tips scripts with trend hooks"""
    import random
    from transformers import pipeline
    import torch
    
    class ContentEngine:
        def __init__(self, config):
            self.config = config
            try:
                self.generator = pipeline(
                    "text-generation", model="microsoft/phi-2",
                    torch_dtype=torch.float16 if torch.cuda.is_available() else torch.float32,
                    device=0 if torch.cuda.is_available() else -1
                )
                self.use_ai = True
            except:
                print("⚠️  Could not load Phi-2, using template-based generation")
                self.use_ai = False
        
        def generate_script(self, topic_idx=None, platform='youtube_shorts'):
            if topic_idx is None:
                topic_idx = random.randint(0, len(self.config.CAR_TIPS) - 1)
            
            topic = self.config.CAR_TIPS[topic_idx]
            hook = random.choice(self.config.TREND_HOOKS)
            
            if platform == 'tiktok':
                duration = 60
            elif platform == 'instagram_reels':
                duration = 90
            else:
                duration = 60
            
            script_lines = [
                f"{hook}",
                "",
                f"{topic['title']} - here's what you need to know.",
                "",
            ]
            
            for i, tip in enumerate(topic['tips'][:4], 1):
                script_lines.append(f"Number {i}: {tip}")
                script_lines.append("")
            
            script_lines.extend([
                "Don't let this happen to your car!",
                "",
                "Follow for more car tips that save you money.",
                "",
                "Drop a 🔧 if this helped you!",
            ])
            
            full_script = "\\n".join(script_lines)
            
            hashtags = [
                "#CarTips", "#AutoCare", "#CarMaintenance", "#DrivingTips",
                "#CarHacks", "#AutoRepair", "#CarLife", "#VehicleCare",
                f"#{topic['title'].replace(' ', '')}", "#Cars", "#MechanicTips"
            ]
            
            caption = f"{hook} {topic['title']} 🚗💨 Save this for later! {' '.join(hashtags[:5])}"
            
            return {
                'hook': hook, 'title': topic['title'], 'script': full_script,
                'clean_script': ' '.join([line for line in script_lines if line]),
                'caption': caption, 'hashtags': hashtags, 'duration': duration,
                'platform': platform, 'tips': topic['tips'][:4],
            }
        
        def generate_all_scripts(self):
            platforms = ['youtube_shorts', 'tiktok', 'instagram_reels', 'youtube_shorts', 'tiktok']
            scripts = []
            used_topics = set()
            for i, platform in enumerate(platforms, 1):
                available = [j for j in range(len(self.config.CAR_TIPS)) if j not in used_topics]
                if not available:
                    used_topics.clear()
                    available = list(range(len(self.config.CAR_TIPS)))
                topic_idx = random.choice(available)
                used_topics.add(topic_idx)
                script = self.generate_script(topic_idx, platform)
                script['video_number'] = i
                scripts.append(script)
            return scripts
    
    return ContentEngine(config)


